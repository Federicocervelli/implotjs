{
  "name": "implotjs",
  "version": "0.1.3",
  "author": {
    "name": "Federico Cervelli",
    "email": "federicocervelli01@gmail.com",
    "url": "https://cervelli.dev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Federicocervelli/implotjs.git"
  },
  "description": "Managed-canvas ImPlot wrapper for JavaScript and TypeScript.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist"
  ],
  "scripts": {
    "build": "bash scripts/build-wasm.sh",
    "clean": "rm -rf build dist",
    "package:test": "bash scripts/package-smoke-test.sh",
    "prepack": "bash scripts/build-wasm.sh",
    "start": "python3 -m http.server 8000",
    "start:test": "bash scripts/start-test-server.sh",
    "generate:readme": "bun run scripts/generate-readme.ts",
    "release:patch": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "keywords": [
    "imgui",
    "implot",
    "wasm",
    "emscripten",
    "webassembly"
  ]
}
